---
interface Props {
  title: string;
  description: string;
  canonical?: string;
  image?: string;
  type?: string;
}

const {
  title,
  description,
  canonical = Astro.url.href,
  image = "/images/og-default.jpg",
  type = "website",
} = Astro.props;

const site = "https://creatorstack2-0.pages.dev";

const imageUrl =
  image.startsWith("http")
    ? image
    : `${site}${image}`;
---

<title>{title}</title>

<meta charset="UTF-8" />

<meta
  name="viewport"
  content="width=device-width, initial-scale=1"
/>

<meta
  name="description"
  content={description}
/>

<meta
  name="robots"
  content="index, follow"
/>

<link
  rel="canonical"
  href={canonical}
/>

<meta
  property="og:type"
  content={type}
/>

<meta
  property="og:title"
  content={title}
/>

<meta
  property="og:description"
  content={description}
/>

<meta
  property="og:url"
  content={canonical}
/>

<meta
  property="og:image"
  content={imageUrl}
/>

<meta
  property="og:site_name"
  content="CreatorStack"
/>

<meta
  name="twitter:card"
  content="summary_large_image"
/>

<meta
  name="twitter:title"
  content={title}
/>

<meta
  name="twitter:description"
  content={description}
/>

<meta
  name="twitter:image"
  content={imageUrl}
/>

<meta
  name="theme-color"
  content="#2563eb"
/>