<section class="bg-white py-28">

  <div class="mx-auto max-w-7xl px-6">

    <div class="text-center">

      <span class="rounded-full bg-green-100 px-5 py-2 text-sm font-bold text-green-700">
        🔥 Latest Reviews
      </span>

      <h2 class="mt-8 text-5xl font-extrabold">
        Fresh AI Tool Reviews
      </h2>

      <p class="mx-auto mt-6 max-w-3xl text-xl text-gray-600">
        Our newest hands-on reviews of the best AI software.
      </p>

    </div>

    <div class="mt-20 grid gap-10 md:grid-cols-2 xl:grid-cols-3">

      <!-- CARD -->

      <a href="/reviews/veed" class="group overflow-hidden rounded-3xl border bg-white shadow-lg transition hover:-translate-y-3 hover:shadow-2xl">

        <img
          src="/images/reviews/veed/dashboard.webp"
          class="h-56 w-full object-cover"
          alt="VEED"
        >

        <div class="p-8">

          <div class="flex items-center justify-between">

            <span class="rounded-full bg-blue-100 px-3 py-2 text-sm font-bold text-blue-700">
              AI Video
            </span>

            <span class="font-bold text-yellow-500">
              ⭐ 4.8
            </span>

          </div>

          <h3 class="mt-6 text-2xl font-bold group-hover:text-blue-600">
            VEED Review 2026
          </h3>

          <p class="mt-4 leading-8 text-gray-600">
            Complete review of one of the best browser-based AI video editors.
          </p>

          <div class="mt-8 flex justify-between text-sm text-gray-500">

            <span>July 2026</span>

            <span>8 min read</span>

          </div>

        </div>

      </a>

      <!-- CARD -->

      <div class="rounded-3xl border bg-gray-50 p-12 text-center">

        <div class="text-6xl">
          🚧
        </div>

        <h3 class="mt-8 text-2xl font-bold">
          Coming Soon
        </h3>

        <p class="mt-4 text-gray-600">
          ChatGPT Review
        </p>

      </div>

      <!-- CARD -->

      <div class="rounded-3xl border bg-gray-50 p-12 text-center">

        <div class="text-6xl">
          🚧
        </div>

        <h3 class="mt-8 text-2xl font-bold">
          Coming Soon
        </h3>

        <p class="mt-4 text-gray-600">
          Canva AI Review
        </p>

      </div>

    </div>

  </div>

</section>