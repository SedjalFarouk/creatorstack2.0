---
const {
  tool1,
  tool2,
  score1,
  score2,
} = Astro.props;
---

<section class="mx-auto max-w-7xl px-6 py-20">

<div class="grid gap-8 md:grid-cols-2">

<div class="rounded-3xl border bg-white p-8 shadow-sm">

<h2 class="text-3xl font-bold">
{tool1}
</h2>

<div class="mt-6 text-6xl font-extrabold text-blue-600">
{score1}
</div>

<p class="text-gray-500">
Overall Score
</p>

</div>

<div class="rounded-3xl border bg-white p-8 shadow-sm">

<h2 class="text-3xl font-bold">
{tool2}
</h2>

<div class="mt-6 text-6xl font-extrabold text-gray-700">
{score2}
</div>

<p class="text-gray-500">
Overall Score
</p>

</div>

</div>

</section>