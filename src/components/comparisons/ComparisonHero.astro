---
const {
  title,
  category,
  description,
  logo1,
  logo2,
  tool1,
  tool2,
} = Astro.props;
---

<section class="mx-auto max-w-7xl px-6 py-20">

  <div class="text-center">

    <span class="rounded-full bg-blue-100 px-4 py-2 text-sm font-semibold text-blue-700">
      {category}
    </span>

    <div class="mt-10 flex items-center justify-center gap-8">

      <img
        src={logo1}
        alt={tool1}
        class="h-20 w-20 rounded-2xl bg-gray-100 p-3 object-contain"
      />

      <span class="text-3xl font-bold text-gray-400">VS</span>

      <img
        src={logo2}
        alt={tool2}
        class="h-20 w-20 rounded-2xl bg-gray-100 p-3 object-contain"
      />

    </div>

    <h1 class="mt-8 text-5xl font-extrabold">
      {title}
    </h1>

    <p class="mx-auto mt-6 max-w-3xl text-xl text-gray-600">
      {description}
    </p>

  </div>

</section>