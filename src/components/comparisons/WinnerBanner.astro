---
const { winner } = Astro.props;
---

<section class="mx-auto max-w-5xl px-6">

  <div class="rounded-3xl bg-gradient-to-r from-blue-600 to-indigo-600 p-10 text-center text-white">

    <div class="text-5xl">🏆</div>

    <h2 class="mt-5 text-4xl font-bold">
      Winner: {winner}
    </h2>

    <p class="mt-4 text-blue-100">
      Based on our testing and evaluation.
    </p>

  </div>

</section>