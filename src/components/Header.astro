---
import { Search } from "lucide-astro";
---

<header class="sticky top-0 z-50 border-b border-gray-200 bg-white/90 backdrop-blur-md">

  <div class="mx-auto flex h-20 max-w-7xl items-center justify-between px-6">

    <!-- Logo -->

    <a href="/" class="flex items-center gap-4">

      <img
        src="/logo.svg"
        alt="CreatorStack"
        class="h-12 w-12"
      />

      <div>

        <h1 class="text-2xl font-extrabold">
          Creator<span class="text-blue-600">Stack</span>
        </h1>

        <p class="text-xs text-gray-500">
          Discover the Best AI Tools
        </p>

      </div>

    </a>

    <!-- Navigation -->

    <nav class="hidden items-center gap-8 font-medium lg:flex">

      <a
        href="/"
        class="transition hover:text-blue-600"
      >
        Home
      </a>

      <a
        href="/reviews"
        class="transition hover:text-blue-600"
      >
        Reviews
      </a>

      <a
        href="/categories"
        class="transition hover:text-blue-600"
      >
        Categories
      </a>

      <a
        href="/comparisons"
        class="transition hover:text-blue-600"
      >
        Comparisons
      </a>

      <a
        href="/about"
        class="transition hover:text-blue-600"
      >
        About
      </a>

      <a
        href="/contact"
        class="transition hover:text-blue-600"
      >
        Contact
      </a>

    </nav>

    <!-- Right Side -->

    <div class="flex items-center gap-3">

      <a
        href="/search"
        class="rounded-xl border border-gray-200 p-3 transition hover:bg-gray-100"
      >
        <Search size={20} />
      </a>

      <a
        href="#newsletter"
        class="rounded-xl bg-blue-600 px-5 py-3 font-semibold text-white transition hover:bg-blue-700"
      >
        Subscribe
      </a>

    </div>

  </div>

</header>