---
interface Props {
  price: string;
  website: string;
}

const { price, website } = Astro.props;
---

<section id="pricing" class="mx-auto max-w-7xl px-6 py-24">

  <div class="text-center">

    <span class="rounded-full bg-blue-100 px-5 py-2 text-sm font-bold text-blue-700">
      💰 Pricing
    </span>

    <h2 class="mt-8 text-5xl font-extrabold">
      VEED Pricing Plans
    </h2>

    <p class="mx-auto mt-6 max-w-3xl text-xl text-gray-600">
      VEED offers flexible plans for beginners, creators, professionals and businesses.
    </p>

  </div>

  <div class="mt-20 grid gap-8 lg:grid-cols-3">

    <!-- FREE -->

    <div class="rounded-3xl border bg-white p-10 shadow-lg">

      <h3 class="text-2xl font-bold">
        Free
      </h3>

      <div class="mt-6 text-5xl font-extrabold">
        $0
      </div>

      <ul class="mt-8 space-y-4 text-gray-600">

        <li>✅ Basic Editing</li>
        <li>✅ AI Subtitles</li>
        <li>✅ Watermarked Exports</li>
        <li>✅ Limited AI Features</li>

      </ul>

    </div>

    <!-- PRO -->

    <div class="relative rounded-3xl border-2 border-blue-600 bg-blue-600 p-10 text-white shadow-2xl scale-105">

      <div class="absolute -top-4 left-1/2 -translate-x-1/2">

        <span class="rounded-full bg-yellow-400 px-5 py-2 text-sm font-bold text-black">

          ⭐ Most Popular

        </span>

      </div>

      <h3 class="mt-4 text-2xl font-bold">

        Pro

      </h3>

      <div class="mt-6 text-5xl font-extrabold">

        {price}

      </div>

      <ul class="mt-8 space-y-4">

        <li>✅ Unlimited Projects</li>
        <li>✅ Premium Templates</li>
        <li>✅ AI Video Generator</li>
        <li>✅ Brand Kit</li>
        <li>✅ No Watermark</li>

      </ul>

      <a
        href={website}
        target="_blank"
        rel="nofollow sponsored noopener"
        class="mt-10 block rounded-2xl bg-white py-5 text-center text-lg font-bold text-blue-600 transition hover:scale-105"
      >

        🚀 Try VEED

      </a>

      <p class="mt-5 text-center text-sm text-blue-100">

        No credit card required for the free plan.

      </p>

    </div>

    <!-- BUSINESS -->

    <div class="rounded-3xl border bg-white p-10 shadow-lg">

      <h3 class="text-2xl font-bold">

        Business

      </h3>

      <div class="mt-6 text-5xl font-extrabold">

        Custom

      </div>

      <ul class="mt-8 space-y-4 text-gray-600">

        <li>✅ Team Workspace</li>
        <li>✅ Shared Assets</li>
        <li>✅ Collaboration</li>
        <li>✅ Priority Support</li>
        <li>✅ Enterprise Security</li>

      </ul>

    </div>

  </div>

</section>