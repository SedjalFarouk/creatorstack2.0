---
interface Props {
  title: string;
  description: string;
  category: string;
  rating: number;
  logo: string;
}

const { title, description, category, rating, logo } = Astro.props;
---

<section class="border-b bg-gradient-to-br from-slate-50 via-white to-blue-50">

  <div class="mx-auto max-w-7xl px-6 py-20">

    <div class="grid items-center gap-14 lg:grid-cols-[180px_1fr]">

      <!-- Logo -->

      <div class="flex justify-center">

        <div class="flex h-40 w-40 items-center justify-center rounded-3xl border border-gray-200 bg-white p-8 shadow-xl">

          <img
            src={logo}
            alt={title}
            class="max-h-full max-w-full object-contain"
          />

        </div>

      </div>

      <!-- Content -->

      <div>

        <div class="mb-5 flex flex-wrap gap-3">

          <span class="rounded-full bg-blue-100 px-4 py-2 text-sm font-bold text-blue-700">
            {category}
          </span>

          <span class="rounded-full bg-green-100 px-4 py-2 text-sm font-bold text-green-700">
            ⭐ Editor's Choice
          </span>

          <span class="rounded-full bg-gray-100 px-4 py-2 text-sm font-bold text-gray-700">
            Updated July 2026
          </span>

        </div>

        <h1 class="text-5xl font-extrabold leading-tight">

          {title}

        </h1>

        <p class="mt-8 max-w-3xl text-xl leading-9 text-gray-600">

          {description}

        </p>

        <!-- Rating -->

        <div class="mt-10 flex flex-wrap items-center gap-6">

          <div class="flex items-center gap-4">

            <div class="text-5xl font-extrabold text-blue-600">

              {rating}

            </div>

            <div>

              <div class="text-2xl text-yellow-500">

                ★★★★★

              </div>

              <p class="font-semibold text-gray-600">

                Excellent

              </p>

            </div>

          </div>

        </div>

        <!-- Buttons -->

        <div class="mt-12 flex flex-wrap gap-5">

          <a
            href="#affiliate"
            class="rounded-2xl bg-blue-600 px-8 py-4 text-lg font-bold text-white transition hover:bg-blue-700"
          >
            Visit VEED →
          </a>

          <a
            href="#pricing"
            class="rounded-2xl border border-gray-300 bg-white px-8 py-4 text-lg font-semibold transition hover:bg-gray-100"
          >
            View Pricing
          </a>

        </div>

        <!-- Trust -->

        <div class="mt-12 flex flex-wrap gap-8 text-sm font-medium text-gray-500">

          <span>✅ Hands-on Tested</span>

          <span>✅ Updated Monthly</span>

          <span>✅ Honest Review</span>

          <span>✅ No Sponsored Ratings</span>

        </div>

      </div>

    </div>

  </div>

</section>