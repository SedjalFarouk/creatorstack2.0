---
interface Props {
  title: string;
  description: string;
  category: string;
  rating: number;
  logo: string;
}

const {
  title,
  description,
  category,
  rating,
  logo
} = Astro.props;
---

<section class="bg-gradient-to-b from-blue-50 to-white border-b">

  <div class="mx-auto max-w-7xl px-6 py-20">

    <div class="grid gap-12 lg:grid-cols-[2fr_1fr] items-center">

      <!-- LEFT -->

      <div>

        <div class="flex flex-wrap gap-3">

          <span class="rounded-full bg-blue-100 px-4 py-2 text-sm font-semibold text-blue-700">
            {category}
          </span>

          <span class="rounded-full bg-green-100 px-4 py-2 text-sm font-semibold text-green-700">
            🏆 Editor's Choice
          </span>

          <span class="rounded-full bg-orange-100 px-4 py-2 text-sm font-semibold text-orange-700">
            ✓ Tested by CreatorStack
          </span>

        </div>

        <div class="mt-8 flex items-center gap-6">

          <img
            src={logo}
            alt={title}
            class="h-24 w-24 rounded-3xl border bg-white p-3 shadow-lg"
          />

          <div>

            <h1 class="text-5xl font-extrabold tracking-tight">
              {title}
            </h1>

            <p class="mt-4 max-w-2xl text-xl text-gray-600">
              {description}
            </p>

          </div>

        </div>

        <div class="mt-10 flex flex-wrap items-center gap-6">

          <div class="flex items-center gap-2">

            <span class="text-4xl font-bold">
              {rating}
            </span>

            <div>

              <div class="text-yellow-500 text-xl">
                ★★★★★
              </div>

              <div class="text-sm text-gray-500">
                Overall Rating
              </div>

            </div>

          </div>

          <div class="h-10 w-px bg-gray-300"></div>

          <div class="text-gray-600">

            Updated July 2026

          </div>

          <div class="h-10 w-px bg-gray-300"></div>

          <div class="text-gray-600">

            40+ Hours Tested

          </div>

        </div>

      </div>

      <!-- RIGHT -->

      <div>

        <div class="rounded-3xl border bg-white p-8 shadow-xl">

          <div class="text-center">

            <div class="text-6xl font-extrabold text-blue-600">
              {rating}
            </div>

            <div class="mt-2 text-gray-500">
              Overall Score
            </div>

          </div>

          <div class="mt-8 space-y-5">

            <div>

              <div class="mb-1 flex justify-between text-sm">

                <span>Ease of Use</span>

                <span>5/5</span>

              </div>

              <div class="h-2 rounded-full bg-gray-200">

                <div class="h-2 w-full rounded-full bg-blue-600"></div>

              </div>

            </div>

            <div>

              <div class="mb-1 flex justify-between text-sm">

                <span>Features</span>

                <span>4.8/5</span>

              </div>

              <div class="h-2 rounded-full bg-gray-200">

                <div class="h-2 w-[96%] rounded-full bg-blue-600"></div>

              </div>

            </div>

            <div>

              <div class="mb-1 flex justify-between text-sm">

                <span>Pricing</span>

                <span>4.5/5</span>

              </div>

              <div class="h-2 rounded-full bg-gray-200">

                <div class="h-2 w-[90%] rounded-full bg-blue-600"></div>

              </div>

            </div>

            <div>

              <div class="mb-1 flex justify-between text-sm">

                <span>Support</span>

                <span>4.7/5</span>

              </div>

              <div class="h-2 rounded-full bg-gray-200">

                <div class="h-2 w-[94%] rounded-full bg-blue-600"></div>

              </div>

            </div>

          </div>

          <a
            href="#affiliate"
            class="mt-10 block rounded-2xl bg-blue-600 py-4 text-center text-lg font-bold text-white transition hover:bg-blue-700"
          >
            🚀 Visit VEED
          </a>

          <a
            href="#pricing"
            class="mt-4 block rounded-2xl border py-4 text-center font-semibold transition hover:bg-gray-50"
          >
            View Pricing
          </a>

        </div>

      </div>

    </div>

  </div>

</section>