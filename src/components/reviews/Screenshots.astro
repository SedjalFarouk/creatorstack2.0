---
const screenshots = [
  {
    image: "/images/screenshots/veed-editor.jpg",
    title: "Video Editor"
  },
  {
    image: "/images/screenshots/veed-subtitles.jpg",
    title: "AI Subtitles"
  },
  {
    image: "/images/screenshots/veed-templates.jpg",
    title: "Templates"
  },
  {
    image: "/images/screenshots/veed-export.jpg",
    title: "Export Settings"
  }
];
---

<section class="bg-gray-50 py-24">

  <div class="mx-auto max-w-7xl px-6">

    <div class="text-center">

      <span class="rounded-full bg-blue-100 px-4 py-2 text-sm font-semibold text-blue-700">
        🖼 Screenshots
      </span>

      <h2 class="mt-6 text-5xl font-extrabold">
        Take a Look Inside VEED
      </h2>

      <p class="mx-auto mt-6 max-w-3xl text-xl text-gray-600">
        These screenshots show the interface we tested during our hands-on review.
      </p>

    </div>

    <!-- Featured Screenshot -->

    <div class="mt-20 overflow-hidden rounded-3xl border bg-white shadow-xl">

      <img
        src="/images/screenshots/veed-editor.jpg"
        alt="VEED Editor"
        class="w-full transition duration-500 hover:scale-105"
      />

    </div>

    <!-- Gallery -->

    <div class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-4">

      {
        screenshots.map((shot) => (

          <div class="group overflow-hidden rounded-3xl border bg-white shadow-sm transition hover:-translate-y-2 hover:shadow-xl">

            <img
              src={shot.image}
              alt={shot.title}
              class="h-56 w-full object-cover transition duration-500 group-hover:scale-110"
            />

            <div class="p-5">

              <h3 class="font-semibold">
                {shot.title}
              </h3>

            </div>

          </div>

        ))
      }

    </div>

  </div>

</section>