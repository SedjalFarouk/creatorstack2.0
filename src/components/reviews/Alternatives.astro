---
const alternatives = [
  {
    name: "CapCut",
    description: "Best free video editor with excellent mobile editing.",
    rating: "4.7",
    badge: "Best Free",
    href: "#"
  },
  {
    name: "Canva AI",
    description: "Perfect for social media graphics and quick videos.",
    rating: "4.8",
    badge: "Best Design",
    href: "#"
  },
  {
    name: "Descript",
    description: "Ideal for podcast editing and AI transcription.",
    rating: "4.6",
    badge: "Best Podcast",
    href: "#"
  }
];
---

<section class="bg-gray-50 py-24">

<div class="mx-auto max-w-7xl px-6">

<div class="text-center">

<span class="rounded-full bg-blue-100 px-4 py-2 text-sm font-semibold text-blue-700">
🔥 Alternatives
</span>

<h2 class="mt-6 text-5xl font-extrabold">
Best VEED Alternatives
</h2>

<p class="mx-auto mt-6 max-w-3xl text-xl text-gray-600">
If VEED isn't the perfect fit, these are our favorite alternatives.
</p>

</div>

<div class="mt-20 grid gap-8 lg:grid-cols-3">

{
alternatives.map(tool => (

<div class="rounded-3xl border bg-white p-8 shadow-sm transition hover:-translate-y-2 hover:shadow-xl">

<div class="flex justify-between items-center">

<h3 class="text-2xl font-bold">

{tool.name}

</h3>

<span class="rounded-full bg-blue-600 px-3 py-1 text-white text-sm">

{tool.badge}

</span>

</div>

<p class="mt-6 text-gray-600">

{tool.description}

</p>

<div class="mt-8 flex justify-between">

<span class="font-bold text-blue-600">

⭐ {tool.rating}/5

</span>

<a
href={tool.href}
class="font-semibold text-blue-600 hover:underline"
>

Read Review →

</a>

</div>

</div>

))
}

</div>

</div>

</section>