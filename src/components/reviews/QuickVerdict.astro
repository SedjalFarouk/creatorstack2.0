---
interface Props {
  score: number;
  summary: string;
}

const { score, summary } = Astro.props;
---

<section class="mx-auto max-w-6xl px-6 py-14">

  <div class="grid gap-8 lg:grid-cols-[260px_1fr]">

    <!-- SCORE CARD -->

    <div class="rounded-3xl border border-gray-200 bg-white p-8 shadow-lg">

      <p class="text-center text-sm font-semibold uppercase tracking-widest text-gray-500">
        Overall Score
      </p>

      <div class="mt-5 text-center">

        <div class="text-6xl font-extrabold text-blue-600">
          {score}
        </div>

        <div class="mt-3 text-yellow-500 text-2xl">
          ★★★★★
        </div>

        <p class="mt-3 font-semibold text-green-600">
          Excellent
        </p>

      </div>

      <a
        href="#affiliate"
        class="mt-8 block rounded-2xl bg-blue-600 py-4 text-center font-bold text-white transition hover:bg-blue-700"
      >
        Visit VEED →
      </a>

    </div>

    <!-- QUICK VERDICT -->

    <div class="rounded-3xl border border-gray-200 bg-white p-10 shadow-lg">

      <span class="rounded-full bg-blue-100 px-4 py-2 text-sm font-semibold text-blue-700">
        Quick Verdict
      </span>

      <h2 class="mt-6 text-3xl font-bold">
        Is VEED Worth It?
      </h2>

      <p class="mt-6 text-lg leading-8 text-gray-600">
        {summary}
      </p>

      <div class="mt-10 grid gap-6 md:grid-cols-3">

        <div>

          <p class="text-sm font-semibold uppercase tracking-wide text-gray-500">
            Best For
          </p>

          <p class="mt-2 font-semibold">
            Content Creators
          </p>

        </div>

        <div>

          <p class="text-sm font-semibold uppercase tracking-wide text-gray-500">
            Starting Price
          </p>

          <p class="mt-2 font-semibold">
            $12/month
          </p>

        </div>

        <div>

          <p class="text-sm font-semibold uppercase tracking-wide text-gray-500">
            Free Plan
          </p>

          <p class="mt-2 font-semibold text-green-600">
            Yes
          </p>

        </div>

      </div>

    </div>

  </div>

</section>