---
interface Props {
  score: number;
  summary: string;
}

const { score, summary } = Astro.props;

const categories = [
  { name: "Ease of Use", score: 5.0 },
  { name: "Features", score: 4.8 },
  { name: "Value", score: 4.7 },
  { name: "Performance", score: 4.9 },
  { name: "Support", score: 4.6 },
  { name: "AI Features", score: 4.9 },
];
---

<section class="bg-white">

  <div class="mx-auto max-w-7xl px-6 py-20">

    <div class="text-center">

      <span class="rounded-full bg-blue-100 px-4 py-2 text-sm font-semibold text-blue-700">
        📊 Overall Score
      </span>

      <h2 class="mt-6 text-4xl font-extrabold">
        Our Verdict
      </h2>

      <p class="mx-auto mt-6 max-w-3xl text-xl text-gray-600">
        {summary}
      </p>

    </div>

    <div class="mt-16 grid gap-10 lg:grid-cols-[350px_1fr]">

      <!-- LEFT CARD -->

      <div class="rounded-3xl border bg-gradient-to-br from-blue-600 to-blue-700 p-10 text-white shadow-xl">

        <div class="text-center">

          <div class="text-7xl font-extrabold">
            {score}
          </div>

          <div class="mt-3 text-blue-100">
            Overall Rating
          </div>

          <div class="mt-4 text-3xl">
            ★★★★★
          </div>

          <div class="mt-6 rounded-full bg-white/20 px-4 py-2 text-sm">
            Editor's Choice 2026
          </div>

        </div>

      </div>

      <!-- RIGHT -->

      <div class="grid gap-6 md:grid-cols-2">

        {
          categories.map((item) => (

            <div class="rounded-2xl border bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-lg">

              <div class="flex justify-between">

                <span class="font-semibold">
                  {item.name}
                </span>

                <span class="font-bold text-blue-600">
                  {item.score}
                </span>

              </div>

              <div class="mt-4 h-3 rounded-full bg-gray-200">

                <div
                  class="h-3 rounded-full bg-blue-600"
                  style={`width:${item.score * 20}%`}
                ></div>

              </div>

            </div>

          ))
        }

      </div>

    </div>

  </div>

</section>