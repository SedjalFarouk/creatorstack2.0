---
interface Props{
affiliateLink:string;
}

const {affiliateLink}=Astro.props;
---

<div class="fixed bottom-6 left-1/2 z-50 -translate-x-1/2">

<a

href={affiliateLink}

target="_blank"

rel="nofollow sponsored noopener"

class="rounded-full bg-blue-600 px-8 py-4 font-bold text-white shadow-2xl transition hover:scale-105 hover:bg-blue-700"

>

🚀 Try VEED Free

</a>

</div>