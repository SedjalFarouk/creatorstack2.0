---
interface Props {
  bestFor: string[];
}

const { bestFor } = Astro.props;

const icons: Record<string, string> = {
  "YouTubers": "🎥",
  "TikTok Creators": "📱",
  "Marketing Teams": "📈",
  "Freelancers": "💼",
  "Small Businesses": "🏢",
  "Content Creators": "🎬",
  "Educators": "🎓",
};

const descriptions: Record<string, string> = {
  "YouTubers": "Edit long-form videos with AI-powered tools.",
  "TikTok Creators": "Create short-form viral content in minutes.",
  "Marketing Teams": "Produce social media ads and campaigns faster.",
  "Freelancers": "Deliver professional videos to clients efficiently.",
  "Small Businesses": "Create marketing videos without hiring editors.",
  "Content Creators": "Speed up your entire content workflow.",
  "Educators": "Build engaging online lessons and tutorials.",
};
---

<section class="bg-gradient-to-b from-white to-gray-50 py-24">

  <div class="mx-auto max-w-7xl px-6">

    <div class="text-center">

      <span class="rounded-full bg-blue-100 px-4 py-2 text-sm font-semibold text-blue-700">
        🎯 Best For
      </span>

      <h2 class="mt-6 text-5xl font-extrabold">
        Who Should Use VEED?
      </h2>

      <p class="mx-auto mt-6 max-w-3xl text-xl text-gray-600">
        VEED is flexible enough for beginners while offering powerful tools for professionals.
      </p>

    </div>

    <div class="mt-20 grid gap-8 md:grid-cols-2 xl:grid-cols-3">

      {
        bestFor.map((item) => (

          <div
            class="group rounded-3xl border bg-white p-8 shadow-sm transition duration-300 hover:-translate-y-2 hover:border-blue-500 hover:shadow-xl"
          >

            <div class="text-6xl">

              {icons[item] ?? "⭐"}

            </div>

            <h3 class="mt-6 text-2xl font-bold group-hover:text-blue-600">

              {item}

            </h3>

            <p class="mt-4 leading-7 text-gray-600">

              {descriptions[item] ?? "A great choice for this type of user."}

            </p>

          </div>

        ))
      }

    </div>

  </div>

</section>