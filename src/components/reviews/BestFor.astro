---
interface Props {
  bestFor: string[];
}

const { bestFor } = Astro.props;
---

<section class="mx-auto max-w-7xl px-6 py-20">

  <div class="rounded-3xl border border-gray-200 bg-white p-12 shadow-xl">

    <div class="text-center">

      <span class="rounded-full bg-blue-100 px-4 py-2 text-sm font-bold text-blue-700">
        Perfect For
      </span>

      <h2 class="mt-6 text-4xl font-extrabold">

        Who Should Use VEED?

      </h2>

      <p class="mt-4 text-lg text-gray-600">

        VEED is an excellent choice for professionals and creators who
        want fast AI-powered video editing.

      </p>

    </div>

    <div class="mt-14 grid gap-6 md:grid-cols-2 lg:grid-cols-3">

      {bestFor.map((item) => (

        <div class="rounded-2xl border border-gray-200 bg-gray-50 p-8 transition hover:-translate-y-2 hover:border-blue-500 hover:bg-blue-50">

          <div class="mb-5 text-4xl">

            🚀

          </div>

          <h3 class="text-xl font-bold">

            {item}

          </h3>

        </div>

      ))}

    </div>

  </div>

</section>