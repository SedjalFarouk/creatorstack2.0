---
const features = [
  {
    icon: "🎬",
    title: "AI Video Editing",
    description: "Edit videos directly in your browser with powerful AI assistance."
  },
  {
    icon: "🎙️",
    title: "AI Voice Generator",
    description: "Generate realistic voiceovers in multiple languages."
  },
  {
    icon: "📝",
    title: "Auto Subtitles",
    description: "Automatically create subtitles with excellent accuracy."
  },
  {
    icon: "🌍",
    title: "Video Translation",
    description: "Translate subtitles and voiceovers into dozens of languages."
  },
  {
    icon: "🎨",
    title: "Templates",
    description: "Hundreds of ready-to-use templates for social media."
  },
  {
    icon: "🤖",
    title: "AI Avatars",
    description: "Create professional AI presenters without recording yourself."
  },
  {
    icon: "📺",
    title: "Screen Recorder",
    description: "Record your screen, webcam or both in one click."
  },
  {
    icon: "☁️",
    title: "Cloud Based",
    description: "No downloads required. Everything works directly online."
  }
];
---

<section class="bg-white py-24">

  <div class="mx-auto max-w-7xl px-6">

    <div class="text-center">

      <span class="rounded-full bg-blue-100 px-4 py-2 text-sm font-semibold text-blue-700">
        ✨ Features
      </span>

      <h2 class="mt-6 text-5xl font-extrabold">
        Everything You Need to Create Videos
      </h2>

      <p class="mx-auto mt-6 max-w-3xl text-xl text-gray-600">
        VEED combines AI tools, video editing, collaboration and publishing into
        one modern platform.
      </p>

    </div>

    <div class="mt-20 grid gap-8 md:grid-cols-2 xl:grid-cols-4">

      {
        features.map((feature) => (

          <div class="group rounded-3xl border bg-white p-8 transition duration-300 hover:-translate-y-2 hover:border-blue-500 hover:shadow-xl">

            <div class="text-5xl">
              {feature.icon}
            </div>

            <h3 class="mt-6 text-2xl font-bold group-hover:text-blue-600">
              {feature.title}
            </h3>

            <p class="mt-4 leading-7 text-gray-600">
              {feature.description}
            </p>

          </div>

        ))
      }

    </div>

  </div>

</section>