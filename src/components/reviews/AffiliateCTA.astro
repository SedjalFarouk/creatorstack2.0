---
interface Props{
buttonText:string;
affiliateLink:string;
}

const {buttonText,affiliateLink}=Astro.props;
---

<section class="py-24">

<div class="mx-auto max-w-5xl px-6">

<div class="rounded-[40px] bg-gradient-to-r from-blue-600 to-indigo-700 p-16 text-center text-white shadow-2xl">

<div class="text-6xl">

🚀

</div>

<h2 class="mt-8 text-5xl font-extrabold">

Ready to Try VEED?

</h2>

<p class="mx-auto mt-6 max-w-2xl text-xl text-blue-100">

If you're looking for one of the easiest AI video editors available today, VEED is an excellent choice for creators, marketers and businesses.

</p>

<a

href={affiliateLink}

target="_blank"

rel="nofollow sponsored noopener"

class="mt-10 inline-block rounded-2xl bg-white px-10 py-5 text-xl font-bold text-blue-700 transition hover:scale-105"

>

{buttonText}

</a>

<p class="mt-6 text-sm text-blue-200">

This helps support CreatorStack at no extra cost to you ❤️

</p>

</div>

</div>

</section>